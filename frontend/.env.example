# Keep this empty in local development so Vite's /api proxy is used.
VITE_API_URL=/api

# Socket.IO server origin. Leave empty to use same-origin (production default).
# Set to http://localhost:5000 ONLY if you're running the backend separately.
# VITE_SOCKET_URL=

# Only used by the Vite development server.
API_PROXY_TARGET=http://localhost:5000
